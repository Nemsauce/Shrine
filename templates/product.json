{
  "sections": {
    "main": {
      "type": "main-product",
      "blocks": {
        "title": {
          "type": "title",
          "settings": {
            "text_size": "h1",
            "title_alignment": "left",
            "uppercase_title": false,
            "margin_top": 0,
            "margin_bottom": 8
          }
        },
        "rating_stars": {
          "type": "rating_stars",
          "settings": {
            "rating": 4.8,
            "star_color": "#F97316",
            "bg_stars_style": "full",
            "bg_star_color": "#e5e7eb",
            "label": "(+1.200 pares salvados en Colombia)",
            "size": 16,
            "alignment": "flex-start",
            "scroll_id": "",
            "margin_top": 0,
            "margin_bottom": 12
          }
        },
        "price": {
          "type": "price",
          "settings": {
            "layout": "price_first",
            "price_color": "accent-2",
            "compare_price_color": "text",
            "margin_top": 12,
            "margin_bottom": 20
          }
        },
        "buy_buttons": {
          "type": "buy_buttons",
          "settings": {
            "show_dynamic_checkout": false,
            "skip_cart": false,
            "uppercase_text": true,
            "icon_scale": 120,
            "icon_spacing": 10,
            "display_price": false,
            "enable_custom_color": true,
            "custom_color": "#F97316",
            "enable_secondary_btn": false,
            "margin_top": 20,
            "margin_bottom": 20
          }
        },
        "shipping_checkpoints": {
          "type": "shipping_checkpoints",
          "settings": {
            "icon_1": "add_shopping_cart",
            "filled_icon_1": false,
            "top_text_1": "<strong>[start_date]<\/strong>",
            "bottom_text_1": "Pedido",
            "min_days_1": 0,
            "max_days_1": 0,
            "icon_2": "local_shipping",
            "filled_icon_2": false,
            "top_text_2": "<strong>[start_date] - [end_date]<\/strong>",
            "bottom_text_2": "En camino",
            "min_days_2": 1,
            "max_days_2": 2,
            "icon_3": "redeem",
            "filled_icon_3": false,
            "top_text_3": "<strong>[start_date] - [end_date]<\/strong>",
            "bottom_text_3": "Entregado",
            "min_days_3": 2,
            "max_days_3": 3,
            "icon_4": "",
            "date_format": "mm_dd",
            "days_labels": "Lun, Mar, Mié, Jue, Vie, Sáb, Dom",
            "months_labels": "Ene, Feb, Mar, Abr, May, Jun, Jul, Ago, Sep, Oct, Nov, Dic",
            "color_scheme": "inverse",
            "margin_top": 20,
            "margin_bottom": 20
          }
        },
        "sticky_atc": {
          "type": "sticky_atc",
          "settings": {
            "function": "add_to_cart",
            "display_when": "after_scroll",
            "button_label": "AGREGAR AL CARRITO",
            "enable_custom_btn_color": true,
            "custom_btn_color": "#F97316",
            "color_scheme": "inverse",
            "star_color": "#F97316",
            "stars_label": "(+1.200 reseñas)",
            "desktop_show_title": true,
            "desktop_show_price": true,
            "desktop_full_button_width": false,
            "mobile_show_title": true,
            "mobile_show_price": true,
            "mobile_full_button_width": true
          }
        },
        "description": {
          "type": "description",
          "settings": {
            "margin_top": 24,
            "margin_bottom": 24
          }
        }
      },
      "block_order": [
        "title",
        "rating_stars",
        "price",
        "buy_buttons",
        "shipping_checkpoints",
        "sticky_atc",
        "description"
      ],
      "settings": {
        "enable_sticky_info": true,
        "disable_prepend": true,
        "media_size": "large",
        "media_position": "left",
        "gallery_layout": "thumbnail_slider",
        "desktop_thumbnails_count": 5,
        "constrain_to_viewport": true,
        "media_fit": "contain",
        "mobile_pagination": "dots_overlay",
        "mobile_thumbnails": "hide",
        "mobile_padding_top": 0,
        "mobile_padding_bottom": 0,
        "desktop_padding_top": 24,
        "desktop_padding_bottom": 36
      }
    },
