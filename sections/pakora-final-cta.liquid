<style>
  .pakora-final-cta {
    background-color: #F97316;
    padding: 64px 20px;
    text-align: center;
  }
  .pakora-final-cta__inner {
    max-width: 600px;
    margin: 0 auto;
  }
  .pakora-final-cta__heading {
    font-size: 2.8rem;
    font-weight: 700;
    color: #FFFFFF;
    margin: 0 0 16px;
    line-height: 1.25;
  }
  .pakora-final-cta__subheading {
    font-size: 1.6rem;
    color: rgba(255,255,255,0.9);
    line-height: 1.6;
    margin: 0 0 28px;
  }
  .pakora-final-cta__price {
    font-size: 2.4rem;
    font-weight: 700;
    color: #FFFFFF;
    margin: 0 0 28px;
    display: block;
  }
  .pakora-final-cta__price span {
    font-size: 1.5rem;
    font-weight: 400;
    opacity: 0.85;
    margin-left: 8px;
  }
  .pakora-final-cta__btn-wrap {
    margin: 0 0 20px;
  }
  .pakora-final-cta__social-proof {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 16px;
    margin-top: 20px;
  }
  .pakora-final-cta__sp-item {
    font-size: 1.35rem;
    color: rgba(255,255,255,0.9);
    display: flex;
    align-items: center;
    gap: 6px;
  }
  @media (min-width: 750px) {
    .pakora-final-cta { padding: 80px 40px; }
    .pakora-final-cta__heading { font-size: 3.6rem; }
    .pakora-final-cta__subheading { font-size: 1.75rem; }
    .pakora-final-cta__price { font-size: 2.8rem; }
  }
</style>

<section class="pakora-final-cta">
  <div class="pakora-final-cta__inner">
    <h2 class="pakora-final-cta__heading">La próxima lluvia no va a dañar tus zapatos.</h2>
    <p class="pakora-final-cta__subheading">
      Únete a más de 1.200 colombianos que ya protegen su calzado con DryStep Pro.
    </p>
    <span class="pakora-final-cta__price">
      $120.000 COP <span>— Envío gratis</span>
    </span>
    <div class="pakora-final-cta__btn-wrap">
      <a href="#product-form" class="pakora-btn-navy" style="border-radius:8px; min-height:56px; font-size:1.75rem; max-width:520px; margin:0 auto;">
        SÍ, QUIERO PROTEGER MIS ZAPATOS →
      </a>
    </div>
    <div class="pakora-final-cta__social-proof">
      <span class="pakora-final-cta__sp-item">⭐⭐⭐⭐⭐</span>
      <span class="pakora-final-cta__sp-item">🔒 Pago seguro</span>
      <span class="pakora-final-cta__sp-item">📦 Envío gratis</span>
      <span class="pakora-final-cta__sp-item">↩️ 30 días de garantía</span>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Pakora — CTA Final",
  "settings": [],
  "presets": [{ "name": "Pakora — CTA Final" }]
}
