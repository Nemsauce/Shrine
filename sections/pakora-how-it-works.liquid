<style>
  .pakora-steps {
    background-color: #1B2A4A;
    padding: 60px 20px;
  }
  .pakora-steps__inner {
    max-width: 800px;
    margin: 0 auto;
  }
  .pakora-steps__heading {
    font-size: 2.4rem;
    font-weight: 700;
    color: #FFFFFF;
    margin: 0 0 40px;
    line-height: 1.3;
    text-align: center;
  }
  .pakora-steps__grid {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .pakora-step {
    display: flex;
    align-items: flex-start;
    gap: 20px;
    padding: 24px 20px;
    background: rgba(255, 255, 255, 0.06);
    border-radius: 12px;
    border: 1px solid rgba(255,255,255,0.1);
    position: relative;
  }
  .pakora-step__number {
    font-size: 3.5rem;
    font-weight: 700;
    color: #F97316;
    line-height: 1;
    flex-shrink: 0;
    min-width: 3.5rem;
    text-align: center;
  }
  .pakora-step__content { flex: 1; }
  .pakora-step__title {
    font-size: 1.8rem;
    font-weight: 700;
    color: #FFFFFF;
    margin: 0 0 8px;
    line-height: 1.3;
  }
  .pakora-step__desc {
    font-size: 1.5rem;
    color: rgba(255, 255, 255, 0.75);
    margin: 0;
    line-height: 1.6;
  }
  @media (min-width: 750px) {
    .pakora-steps { padding: 80px 40px; }
    .pakora-steps__heading { font-size: 3.2rem; }
    .pakora-steps__grid {
      flex-direction: row;
      align-items: stretch;
    }
    .pakora-step {
      flex-direction: column;
      flex: 1;
      align-items: flex-start;
    }
    .pakora-step__title { font-size: 1.9rem; }
    .pakora-step__desc { font-size: 1.6rem; }
  }
</style>

<section class="pakora-steps">
  <div class="pakora-steps__inner">
    <h2 class="pakora-steps__heading">Así de simple.</h2>
    <div class="pakora-steps__grid">

      <div class="pakora-step">
        <span class="pakora-step__number">01</span>
        <div class="pakora-step__content">
          <h3 class="pakora-step__title">Inserta los brazos en tus zapatos</h3>
          <p class="pakora-step__desc">Los brazos extensibles se adaptan a cualquier talla y tipo de calzado.</p>
        </div>
      </div>

      <div class="pakora-step">
        <span class="pakora-step__number">02</span>
        <div class="pakora-step__content">
          <h3 class="pakora-step__title">Selecciona temperatura y tiempo</h3>
          <p class="pakora-step__desc">Ajusta el dial según el material de tus zapatos. El temporizador hace el resto.</p>
        </div>
      </div>

      <div class="pakora-step">
        <span class="pakora-step__number">03</span>
        <div class="pakora-step__content">
          <h3 class="pakora-step__title">Recoge zapatos secos y frescos</h3>
          <p class="pakora-step__desc">En pocas horas tus zapatos estarán listos, sin humedad y sin olor.</p>
        </div>
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Pakora — Cómo Funciona",
  "settings": [],
  "presets": [{ "name": "Pakora — Cómo Funciona" }]
}
{% endschema %}
