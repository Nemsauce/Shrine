<style>
  .pakora-cta-price {
    background-color: #F97316;
    padding: 60px 20px;
    text-align: center;
  }
  .pakora-cta-price__inner {
    max-width: 560px;
    margin: 0 auto;
  }
  .pakora-cta-price__heading {
    font-size: 2.6rem;
    font-weight: 700;
    color: #FFFFFF;
    margin: 0 0 24px;
    line-height: 1.25;
  }
  .pakora-cta-price__prices {
    margin: 0 0 24px;
  }
  .pakora-cta-price__compare {
    font-size: 1.8rem;
    color: rgba(255,255,255,0.7);
    text-decoration: line-through;
    display: block;
    margin-bottom: 4px;
  }
  .pakora-cta-price__current {
    font-size: 3.5rem;
    font-weight: 700;
    color: #FFFFFF;
    display: block;
    line-height: 1;
  }
  .pakora-cta-price__shipping {
    font-size: 1.4rem;
    color: rgba(255,255,255,0.85);
    margin: 8px 0 0;
    display: block;
  }
  .pakora-cta-price__btn-wrap {
    margin: 28px 0 0;
  }
  .pakora-cta-price__security {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 16px;
    margin-top: 16px;
  }
  .pakora-cta-price__security-item {
    font-size: 1.35rem;
    color: rgba(255,255,255,0.9);
    display: flex;
    align-items: center;
    gap: 6px;
  }
  @media (min-width: 750px) {
    .pakora-cta-price { padding: 80px 40px; }
    .pakora-cta-price__heading { font-size: 3.2rem; }
    .pakora-cta-price__current { font-size: 4.2rem; }
  }
</style>

<section class="pakora-cta-price">
  <div class="pakora-cta-price__inner">
    <h2 class="pakora-cta-price__heading">Protege tus zapatos hoy.</h2>
    <div class="pakora-cta-price__prices">
      <span class="pakora-cta-price__compare">~~$150.000~~</span>
      <span class="pakora-cta-price__current">$120.000 COP</span>
      <span class="pakora-cta-price__shipping">Envío gratis · Llega en 2-3 días hábiles</span>
    </div>
    <div class="pakora-cta-price__btn-wrap">
      <a href="#product-form" class="pakora-btn-navy" style="border-radius:8px; min-height:52px; font-size:1.7rem;">
        AGREGAR AL CARRITO →
      </a>
    </div>
    <div class="pakora-cta-price__security">
      <span class="pakora-cta-price__security-item">🔒 Pago 100% seguro</span>
      <span class="pakora-cta-price__security-item">📦 Envío gratis</span>
      <span class="pakora-cta-price__security-item">↩️ Garantía 30 días</span>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Pakora — CTA Precio",
  "settings": [],
  "presets": [{ "name": "Pakora — CTA Precio" }]
}
{% endschema %}
